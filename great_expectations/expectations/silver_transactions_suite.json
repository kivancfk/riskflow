{
  "data_asset_type": null,
  "expectation_suite_name": "silver_transactions_suite",
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "amount",
        "min_value": 0,
        "strict_min": false
      },
      "meta": {
        "notes": "Amount must be non-negative. Negative amounts would indicate ingestion errors."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "is_fraud",
        "value_set": [true, false]
      },
      "meta": {
        "notes": "Silver renames isFraud → is_fraud and casts INT 0/1 → BOOLEAN. Validates the type cast worked."
      }
    },
    {
      "expectation_type": "expect_compound_columns_to_be_unique",
      "kwargs": {
        "column_list": ["nameOrig", "nameDest", "step", "amount"]
      },
      "meta": {
        "notes": "After silver dedup, each (nameOrig, nameDest, step, amount) combination must be unique."
      }
    }
  ],
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.21"
  }
}
